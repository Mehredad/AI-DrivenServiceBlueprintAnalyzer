# Blueprint AI — Environment Variables
# Add ALL of these in Vercel Dashboard → Project → Settings → Environment Variables
# NEVER commit a filled-in .env file to git.

# ── Database (Supabase PostgreSQL — use the connection pooler URL for serverless)
# Supabase Dashboard → Settings → Database → Connection string
# Use "Transaction" mode pooler for serverless (port 6543, not 5432)
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# ── Supabase (for Realtime broadcasting from backend)
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key — used by the API backend only

# ── Supabase (public — used by the frontend for Realtime collaboration)
# This is the anon/public key — safe to expose, protected by Row Level Security
SUPABASE_ANON_KEY=eyJ...      # anon key from Supabase Dashboard → Settings → API

# ── JWT Auth
# Generate: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=replace_with_64_char_random_hex_string

# ── Anthropic (server-side only — NEVER expose to frontend)
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── NVIDIA NIM (free tier — used for lightweight AI tasks like insight generation)
# build.nvidia.com → API Keys
# If not set, all AI tasks fall back to Anthropic.
NIM_API_KEY=nvapi-...

# ── CORS — your Vercel frontend URL (set after first deploy)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── App
ENVIRONMENT=production
LOG_LEVEL=INFO
